# Web Core — PostgreSQL（svc-api / svc-postgres）
POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=change-me

# LINE Reminder Bot（寫入 .env，勿提交真實值）
# LINE Developers → Messaging API → Channel secret
LINE_CHANNEL_SECRET=
# LINE Developers → Messaging API → Channel access token
LINE_CHANNEL_ACCESS_TOKEN=
# line-bot-db 資料庫名稱
LINE_BOT_DB_NAME=line_reminder
# line-bot-db 使用者
LINE_BOT_DB_USER=linebot
# line-bot-db 密碼
LINE_BOT_DB_PASSWORD=change-me

# LINE Reminder Bot — 自然語言
# OpenAI key 可用 LINE_OPENAI_API_KEY；未填則回退 TELEGRAM_OPENAI_API_KEY
# 可選；僅 LINE bot 專用 OpenAI 金鑰
LINE_OPENAI_API_KEY=
# 自然語言解析使用的 OpenAI 模型
LINE_BOT_LLM_MODEL=gpt-4o-mini
# rules | hybrid（hybrid = 規則優先，必要時呼叫 LLM）
LINE_BOT_NLU_MODE=hybrid
# 查詢提醒時是否顯示 Flex 卡片列表
LINE_BOT_FLEX_LIST_ENABLED=true

# Telegram Agent Bot（寫入 .env，勿提交真實值）
# @BotFather 取得的 Bot token
TELEGRAM_BOT_TOKEN=
# 允許使用的 Telegram userId（逗號分隔，可用 @userinfobot 查）
ALLOWED_TELEGRAM_USER_IDS=
# OpenAI 金鑰（閒聊、意圖分類、網頁摘要）
TELEGRAM_OPENAI_API_KEY=
# 內部 API 驗證用隨機字串
TELEGRAM_INTERNAL_API_SECRET=
# Cursor SDK 金鑰（開發任務必填）
TELEGRAM_CURSOR_API_KEY=

# Telegram Agent Bot — LLM / Agent
# 閒聊、意圖分類、網頁摘要使用的 OpenAI 模型
TELEGRAM_LLM_MODEL=gpt-4o-mini
# Cursor Agent 使用的模型
TELEGRAM_AGENT_MODEL=composer-2.5
# llm | rules（訊息意圖判斷方式）
TELEGRAM_INTENT_ROUTER=llm

# Telegram Agent Bot — Dev 任務（cloud / local）
# local = 本機開發測試；cloud = Cursor Cloud Agent（Production 強制）
TELEGRAM_DEV_RUNTIME=cloud
# cloud 模式必填；目標 repo（owner/repo，逗號分隔）
TELEGRAM_CLOUD_REPOS=
# Cloud Agent 預設分支
TELEGRAM_CLOUD_BASE_BRANCH=main
# Cloud Agent 完成後是否自動開 PR
TELEGRAM_CLOUD_AUTO_CREATE_PR=true
# Cloud Agent 自動化中建議關閉 reviewer request
TELEGRAM_CLOUD_SKIP_REVIEWER_REQUEST=true
# 開發任務回覆是否加上簡短、列點提示
TELEGRAM_DEV_BRIEF_REPLY=true
# 開發任務逾時（毫秒，預設 10 分鐘）
TELEGRAM_RUN_TIMEOUT_MS=600000

# Telegram Agent Bot — 網頁擷取
# inline = Bot 直接編排；n8n = 改走 n8n webhook
TELEGRAM_SCRAPE_MODE=inline
# 網頁擷取逾時（毫秒，預設 2 分鐘）
TELEGRAM_SCRAPE_TIMEOUT_MS=120000

# Telegram Agent Bot — 工作目錄與 Webhook
# Production 不再掛載主機 workspace。cloud runtime 僅需容器內安全路徑。
TELEGRAM_DEFAULT_CWD=/app
TELEGRAM_ALLOWED_CWD_ROOTS=/app
# Telegram webhook 目標 URL（需 HTTPS 公網網址）
TELEGRAM_WEBHOOK_URL=https://tgbot.inwanding.com/telegram/webhook

# Telegram Agent Bot — ops（Phase 0A：Bot 不掛載 docker.sock）
TELEGRAM_OPS_ENABLED=true
# 預設 false。為安全考量，Production Bot 不得掛載 /var/run/docker.sock。
TELEGRAM_OPS_DOCKER_ENABLED=false
TELEGRAM_OPS_ALLOWED_CONTAINERS=svc-telegram-bot,svc-telegram-playwright,svc-line-bot,edge-nginx
# 選填。HTTP 健康檢查 URL（逗號分隔，須為 bot 容器內可達）。
# 以下 service key 與 port 已從 docker-compose.yml 驗證：
#   api:3000、line-bot:3000、telegram-playwright:3100、telegram-bot:3001
# TELEGRAM_OPS_HEALTH_URLS=http://api:3000/health,http://line-bot:3000/health,http://telegram-playwright:3100/health,http://telegram-bot:3001/health
TELEGRAM_OPS_HEALTH_URLS=
TELEGRAM_OPS_COMMAND_TIMEOUT_MS=30000
TELEGRAM_OPS_LOG_TAIL_LINES=50

# Telegram Agent Bot — GitHub 查詢（Phase 1 唯讀，GH-4）
# 建議使用 read-only fine-grained PAT 或 classic token（僅 repo read）
TELEGRAM_GITHUB_TOKEN=
TELEGRAM_GITHUB_ALLOWED_REPOS=Aiden4939/telegram-agent-bot
TELEGRAM_GITHUB_ISSUE_LIMIT=10

# Task guardrails（Phase 1B）
TASK_MAX_MODEL_CALLS=30
TASK_MAX_TOOL_CALLS=80
TASK_MAX_RUNTIME_MS=900000
TASK_MAX_ESTIMATED_COST=5
DAILY_MAX_ESTIMATED_COST=50
MONTHLY_MAX_ESTIMATED_COST=500
LOG_MAX_LINES=80
LOG_MAX_BYTES=12000
TASK_APPROVAL_TTL_MS=900000
TOOL_CALL_TIMEOUT_MS=120000
MODEL_CALL_TIMEOUT_MS=120000
TASK_HEARTBEAT_TIMEOUT_MS=300000
USER_MESSAGE_PER_MINUTE_LIMIT=15
USER_CONCURRENT_DEV_TASK_LIMIT=1
GLOBAL_CONCURRENT_AGENT_LIMIT=3
MIN_AGENT_START_INTERVAL_MS=60000
TASK_CI_POLL_INTERVAL_SECONDS=20
TASK_CI_TIMEOUT_SECONDS=1800
TASK_CI_MAX_POLLS=120
TASK_MAX_AGENT_RESUMES=3
TASK_MAX_CI_FIX_ATTEMPTS=3

# Telegram Agent Bot — 台新證券持股查詢（GH-1，.env 準備好後再啟用）
# TELEGRAM_TAISHIN_ENABLED=true
# TELEGRAM_TAISHIN_NATIONAL_ID=
# TELEGRAM_TAISHIN_PASSWORD=
# TELEGRAM_TAISHIN_CERT_PASSWORD=
# 主機上憑證檔路徑（掛載進容器 /run/secrets/taishin-cert.p12）
# TELEGRAM_TAISHIN_CERT_HOST_PATH=/home/aiden/secrets/taishin-cert.p12
# 多帳戶時可指定證券帳號；留空則用登入後第一個
# TELEGRAM_TAISHIN_ACCOUNT_ID=
