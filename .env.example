# Web Core — PostgreSQL（svc-api / svc-postgres）
POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=change-me

# LINE Reminder Bot（寫入 .env，勿提交真實值）
# LINE Developers → Messaging API → Channel secret
LINE_CHANNEL_SECRET=
# LINE Developers → Messaging API → Channel access token
LINE_CHANNEL_ACCESS_TOKEN=
# line-bot-db 資料庫名稱
LINE_BOT_DB_NAME=line_reminder
# line-bot-db 使用者
LINE_BOT_DB_USER=linebot
# line-bot-db 密碼
LINE_BOT_DB_PASSWORD=change-me

# LINE Reminder Bot — 自然語言
# OpenAI key 可用 LINE_OPENAI_API_KEY；未填則回退 TELEGRAM_OPENAI_API_KEY
# 可選；僅 LINE bot 專用 OpenAI 金鑰
LINE_OPENAI_API_KEY=
# 自然語言解析使用的 OpenAI 模型
LINE_BOT_LLM_MODEL=gpt-4o-mini
# rules | hybrid（hybrid = 規則優先，必要時呼叫 LLM）
LINE_BOT_NLU_MODE=hybrid
# 查詢提醒時是否顯示 Flex 卡片列表
LINE_BOT_FLEX_LIST_ENABLED=true

# Telegram Agent Bot（寫入 .env，勿提交真實值）
# @BotFather 取得的 Bot token
TELEGRAM_BOT_TOKEN=
# 允許使用的 Telegram userId（逗號分隔，可用 @userinfobot 查）
ALLOWED_TELEGRAM_USER_IDS=
# OpenAI 金鑰（閒聊、意圖分類、網頁摘要）
TELEGRAM_OPENAI_API_KEY=
# 內部 API 驗證用隨機字串
TELEGRAM_INTERNAL_API_SECRET=
# Cursor SDK 金鑰（開發任務必填）
TELEGRAM_CURSOR_API_KEY=

# Telegram Agent Bot — LLM / Agent
# 閒聊、意圖分類、網頁摘要使用的 OpenAI 模型
TELEGRAM_LLM_MODEL=gpt-4o-mini
# Cursor Agent 使用的模型
TELEGRAM_AGENT_MODEL=composer-2.5
# llm | rules（訊息意圖判斷方式）
TELEGRAM_INTENT_ROUTER=llm

# Telegram Agent Bot — Dev 任務（cloud / local）
# local = 讀容器掛載 /workspace；cloud = Cursor Cloud Agent
TELEGRAM_DEV_RUNTIME=cloud
# cloud 模式必填；目標 repo（owner/repo，逗號分隔）
TELEGRAM_CLOUD_REPOS=
# Cloud Agent 預設分支
TELEGRAM_CLOUD_BASE_BRANCH=main
# Cloud Agent 完成後是否自動開 PR
TELEGRAM_CLOUD_AUTO_CREATE_PR=true
# Cloud Agent 自動化中建議關閉 reviewer request
TELEGRAM_CLOUD_SKIP_REVIEWER_REQUEST=true
# 開發任務回覆是否加上簡短、列點提示
TELEGRAM_DEV_BRIEF_REPLY=true
# 開發任務逾時（毫秒，預設 10 分鐘）
TELEGRAM_RUN_TIMEOUT_MS=600000

# Telegram Agent Bot — 網頁擷取
# inline = Bot 直接編排；n8n = 改走 n8n webhook
TELEGRAM_SCRAPE_MODE=inline
# 網頁擷取逾時（毫秒，預設 2 分鐘）
TELEGRAM_SCRAPE_TIMEOUT_MS=120000

# Telegram Agent Bot — 工作目錄與 Webhook
# 主機上程式碼目錄（掛載進容器 /workspace，供 local dev 任務）
TELEGRAM_WORKSPACE_HOST_PATH=/home/aiden/inwanding
# Agent 預設工作目錄（容器內路徑）
TELEGRAM_DEFAULT_CWD=/workspace
# /cwd 指令允許切換的根目錄（逗號分隔）
TELEGRAM_ALLOWED_CWD_ROOTS=/workspace
# Telegram webhook 目標 URL（需 HTTPS 公網網址）
TELEGRAM_WEBHOOK_URL=https://tgbot.inwanding.com/telegram/webhook

# Telegram Agent Bot — ops Phase 1（查詢型主機操作，需 docker.sock 掛載）
TELEGRAM_OPS_ENABLED=true
TELEGRAM_OPS_DOCKER_ENABLED=true
TELEGRAM_OPS_ALLOWED_CONTAINERS=svc-telegram-bot,svc-telegram-playwright,svc-line-bot,edge-nginx
# 逗號分隔 HTTP 健康檢查 URL（容器內可達，例：http://api:3000/health）
TELEGRAM_OPS_HEALTH_URLS=
TELEGRAM_OPS_COMMAND_TIMEOUT_MS=30000
TELEGRAM_OPS_LOG_TAIL_LINES=50
